// firestore.rules — Fix 39
// Wijziging t.o.v. Fix 38:
// - canWriteZone: ook Hoornaar_ prefix variant accepteren voor achterwaartse compatibiliteit
// - polygons: manager mag schrijven binnen eigen zones

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.role == 'admin';
    }

    function userZones() {
      return get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.zones;
    }

    // Normaliseer zone: strip Hoornaar_ prefix als aanwezig
    function normalizeZ(z) {
      return z == null ? z :
             z == 'Hoornaar_Zeist'      ? 'Zeist'      :
             z == 'Hoornaar_Bilthoven'  ? 'Bilthoven'  :
             z == 'Hoornaar_Driebergen' ? 'Driebergen' :
             z == 'Hoornaar_Utrecht'    ? 'Utrecht'    : z;
    }
    function canWriteZone(z) {
      if (!isSignedIn() || z == null) return false;
      if (isAdmin()) return true;
      let zones = userZones();
      // Check beide varianten: korte naam én Hoornaar_ prefix
      return z in zones || normalizeZ(z) in zones ||
             ('Hoornaar_' + z) in zones;
    }

    match /maps/{year}/{group}/data/markers/{docId} {
      allow read: if true;
      allow create: if isAdmin() || canWriteZone(request.resource.data.zoneId);
      allow update: if isAdmin() || (canWriteZone(request.resource.data.zoneId) && canWriteZone(resource.data.zoneId));
      allow delete: if isAdmin() || canWriteZone(resource.data.zoneId);
    }

    match /maps/{year}/{group}/data/lines/{docId} {
      allow read: if true;
      allow create: if isAdmin() || canWriteZone(request.resource.data.zoneId);
      allow update: if isAdmin() || (canWriteZone(request.resource.data.zoneId) && canWriteZone(resource.data.zoneId));
      allow delete: if isAdmin() || canWriteZone(resource.data.zoneId);
    }

    match /maps/{year}/{group}/data/sectors/{docId} {
      allow read: if true;
      allow create: if isAdmin() || canWriteZone(request.resource.data.zoneId);
      allow update: if isAdmin() || (canWriteZone(request.resource.data.zoneId) && canWriteZone(resource.data.zoneId));
      allow delete: if isAdmin() || canWriteZone(resource.data.zoneId);
    }

    match /maps/{year}/{group}/data/polygons/{docId} {
      allow read: if true;
      allow create: if isAdmin() || canWriteZone(request.resource.data.zoneId);
      allow update: if isAdmin() || (canWriteZone(request.resource.data.zoneId) && canWriteZone(resource.data.zoneId));
      allow delete: if isAdmin() || canWriteZone(resource.data.zoneId);
    }

    match /roles/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      // Admin mag alles schrijven.
      // Eigen gebruiker mag ALLEEN zijn eigen doc aanmaken als het nog niet bestaat
      // (eerste login → pending). Bestaande docs mag alleen admin aanpassen.
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update, delete: if isAdmin();
    }
  }
}
