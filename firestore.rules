// firestore.rules — Fix 27
// Wijziging t.o.v. Fix 26:
// - mail collectie toegevoegd: alleen admin mag schrijven (voor welkomst-emails
//   via Firebase Trigger Email extensie). Lezen geblokkeerd voor iedereen.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.role == 'admin';
    }

    function userZones() {
      return get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.zones;
    }

    function canWriteZone(z) {
      return isAdmin() || (isSignedIn() && z != null && z in userZones());
    }

    match /maps/{year}/{group}/data/markers/{docId} {
      allow read: if true;
      allow create: if isAdmin() || canWriteZone(request.resource.data.zoneId);
      allow update: if isAdmin() || (canWriteZone(request.resource.data.zoneId) && canWriteZone(resource.data.zoneId));
      allow delete: if isAdmin() || canWriteZone(resource.data.zoneId);
    }

    match /maps/{year}/{group}/data/lines/{docId} {
      allow read: if true;
      allow create: if isAdmin() || canWriteZone(request.resource.data.zoneId);
      allow update: if isAdmin() || (canWriteZone(request.resource.data.zoneId) && canWriteZone(resource.data.zoneId));
      allow delete: if isAdmin() || canWriteZone(resource.data.zoneId);
    }

    match /maps/{year}/{group}/data/sectors/{docId} {
      allow read: if true;
      allow create: if isAdmin() || canWriteZone(request.resource.data.zoneId);
      allow update: if isAdmin() || (canWriteZone(request.resource.data.zoneId) && canWriteZone(resource.data.zoneId));
      allow delete: if isAdmin() || canWriteZone(resource.data.zoneId);
    }

    match /maps/{year}/{group}/data/polygons/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /roles/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();
    }

    // Mail collectie voor Firebase Trigger Email extensie.
    // Alleen admin mag documenten aanmaken (= email versturen).
    // Lezen geblokkeerd — de extensie leest intern via service account.
    match /mail/{docId} {
      allow read: if false;
      allow create: if isAdmin();
    }
  }
}
