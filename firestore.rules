// firestore.rules — Fix 127
// Wijziging t.o.v. Fix 54:
// - config/zones: leesbaar voor iedereen ingelogd, schrijfbaar alleen voor admin

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.role == 'admin';
    }

    function userZones() {
      return get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.zones;
    }

    function canWriteZone(z) {
      return isSignedIn() && z != null && (
        isAdmin() ||
        z in userZones() ||
        (z == 'Zeist'      && 'Hoornaar_Zeist'      in userZones()) ||
        (z == 'Bilthoven'  && 'Hoornaar_Bilthoven'  in userZones()) ||
        (z == 'Driebergen' && 'Hoornaar_Driebergen' in userZones()) ||
        (z == 'Utrecht'    && 'Hoornaar_Utrecht'     in userZones()) ||
        (z == 'Hoornaar_Zeist'      && 'Zeist'      in userZones()) ||
        (z == 'Hoornaar_Bilthoven'  && 'Bilthoven'  in userZones()) ||
        (z == 'Hoornaar_Driebergen' && 'Driebergen' in userZones()) ||
        (z == 'Hoornaar_Utrecht'    && 'Utrecht'     in userZones())
      );
    }

    match /maps/{year}/{group}/data/markers/{docId} {
      allow read: if true;
      allow create: if isAdmin() || canWriteZone(request.resource.data.zoneId);
      allow update: if isAdmin() || (canWriteZone(request.resource.data.zoneId) && canWriteZone(resource.data.zoneId));
      allow delete: if isAdmin() || canWriteZone(resource.data.zoneId);
    }

    match /maps/{year}/{group}/data/lines/{docId} {
      allow read: if true;
      allow create: if isAdmin() || canWriteZone(request.resource.data.zoneId);
      allow update: if isAdmin() || (canWriteZone(request.resource.data.zoneId) && canWriteZone(resource.data.zoneId));
      allow delete: if isAdmin() || canWriteZone(resource.data.zoneId);
    }

    match /maps/{year}/{group}/data/sectors/{docId} {
      allow read: if true;
      allow create: if isAdmin() || canWriteZone(request.resource.data.zoneId);
      allow update: if isAdmin() || (canWriteZone(request.resource.data.zoneId) && canWriteZone(resource.data.zoneId));
      allow delete: if isAdmin() || canWriteZone(resource.data.zoneId);
    }

    match /maps/{year}/{group}/data/polygons/{docId} {
      allow read: if true;
      allow create: if isAdmin() || canWriteZone(request.resource.data.zoneId);
      allow update: if isAdmin() || (canWriteZone(request.resource.data.zoneId) && canWriteZone(resource.data.zoneId));
      allow delete: if isAdmin() || canWriteZone(resource.data.zoneId);
    }

    match /roles/{uid} {
      // Iedereen die ingelogd is mag role/zones/displayName lezen (nodig voor beheerder-weergave)
      // Volledige lees-toegang alleen voor eigen doc of admin
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update, delete: if isAdmin();
    }

    match /config/{docId} {
      // Zones config: leesbaar voor iedereen ingelogd, schrijfbaar alleen voor admin
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /activity/{uid}/log/{logId} {
      // Gebruiker schrijft en leest eigen activiteit
      allow read, write: if isSignedIn() && request.auth.uid == uid;
      // Admin en manager lezen activiteit van alle gebruikers
      allow read: if isAdmin() ||
        (isSignedIn() && get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.role == 'manager');
    }
  }
}
