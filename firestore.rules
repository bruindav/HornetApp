// firestore.rules — Fix 26
// Wijziging t.o.v. Fix 25:
// roles/{uid} read rule hersteld zodat admin de volledige collectie
// kan lezen (nodig voor gebruikersbeheer panel), maar zonder circulaire
// isAdmin() aanroep. Oplossing: aparte adminDoc() functie die alleen
// wordt aangeroepen vanuit niet-circulaire context, plus een directe
// token-claim check als fallback.
// De roles collectie list/read door admin werkt nu via:
//   allow read: if eigen doc || isAdmin()
// isAdmin() gebruikt get() op het eigen doc — dit is niet circulair
// want de rule voor roles/{uid} matched op een specifiek uid, terwijl
// isAdmin() get() doet op het uid van de ingelogde user. Firebase
// evalueert deze niet als circulair als ze op verschillende paden vallen.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.role == 'admin';
    }

    function userZones() {
      return get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.zones;
    }

    function canWriteZone(z) {
      return isAdmin() || (isSignedIn() && z != null && z in userZones());
    }

    match /maps/{year}/{group}/data/markers/{docId} {
      allow read: if true;
      allow create: if isAdmin() || canWriteZone(request.resource.data.zoneId);
      allow update: if isAdmin() || (canWriteZone(request.resource.data.zoneId) && canWriteZone(resource.data.zoneId));
      allow delete: if isAdmin() || canWriteZone(resource.data.zoneId);
    }

    match /maps/{year}/{group}/data/lines/{docId} {
      allow read: if true;
      allow create: if isAdmin() || canWriteZone(request.resource.data.zoneId);
      allow update: if isAdmin() || (canWriteZone(request.resource.data.zoneId) && canWriteZone(resource.data.zoneId));
      allow delete: if isAdmin() || canWriteZone(resource.data.zoneId);
    }

    match /maps/{year}/{group}/data/sectors/{docId} {
      allow read: if true;
      allow create: if isAdmin() || canWriteZone(request.resource.data.zoneId);
      allow update: if isAdmin() || (canWriteZone(request.resource.data.zoneId) && canWriteZone(resource.data.zoneId));
      allow delete: if isAdmin() || canWriteZone(resource.data.zoneId);
    }

    match /maps/{year}/{group}/data/polygons/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /roles/{uid} {
      // Eigen doc lezen altijd toegestaan.
      // Admin mag alle docs lezen (voor gebruikersbeheer panel).
      // isAdmin() doet get() op roles/{ingelogde uid} — dat is een
      // ander pad dan roles/{uid} die hier gematcht wordt, dus
      // geen circulaire evaluatie.
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();
    }
  }
}
