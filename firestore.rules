// Fix 24 — geen isAdmin() recursie bij roles schrijven
// roles schrijven gebruikt request.auth.uid check ipv get()
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function uid()        { return request.auth.uid; }
    function roleDoc()    { return get(/databases/{database}/documents/roles/$(uid())); }
    function userRole()   { return roleDoc().data.role; }
    function userZones()  { return roleDoc().data.zones; }

    function isAdmin()     { return isSignedIn() && userRole() == 'admin'; }
    function isManager()   { return isSignedIn() && userRole() == 'manager'; }
    function isVolunteer() { return isSignedIn() && userRole() == 'volunteer'; }

    function canWriteInGroup(group) {
      return isAdmin()
          || ( (isManager() || isVolunteer()) && group in userZones() );
    }

    match /maps/{year}/{group}/data/markers/{docId} {
      allow read:                   if isSignedIn();
      allow create, update, delete: if canWriteInGroup(group);
    }
    match /maps/{year}/{group}/data/lines/{docId} {
      allow read:                   if isSignedIn();
      allow create, update, delete: if canWriteInGroup(group);
    }
    match /maps/{year}/{group}/data/sectors/{docId} {
      allow read:                   if isSignedIn();
      allow create, update, delete: if canWriteInGroup(group);
    }
    match /maps/{year}/{group}/data/polygons/{docId} {
      allow read:           if isSignedIn();
      allow create:         if isAdmin() || isManager();
      allow update, delete: if isAdmin()
                            || (isManager() && resource.data.createdBy == uid());
    }

    // Roles: lezen open, schrijven checkt admin-rol via apart pad (geen recursie)
    match /roles/{userId} {
      allow read: if isSignedIn();

      // Nieuwe gebruiker maakt eigen pending doc aan
      allow create: if isSignedIn()
                    && request.auth.uid == userId
                    && request.resource.data.role == 'pending';

      // Admin mag updaten/verwijderen — check via aparte exists() zonder functie
      allow update, delete: if isSignedIn()
                    && get(/databases/{database}/documents/roles/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
