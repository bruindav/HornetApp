// firestore.rules — Fix 40
// Wijziging t.o.v. Fix 39:
// - canWriteZone: geldige Firestore Rules syntax (geen let, geen string +)

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.role == 'admin';
    }

    function userZones() {
      return get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.zones;
    }

    function canWriteZone(z) {
      return isSignedIn() && z != null && (
        isAdmin() ||
        z in userZones() ||
        (z == 'Zeist'      && 'Hoornaar_Zeist'      in userZones()) ||
        (z == 'Bilthoven'  && 'Hoornaar_Bilthoven'  in userZones()) ||
        (z == 'Driebergen' && 'Hoornaar_Driebergen' in userZones()) ||
        (z == 'Utrecht'    && 'Hoornaar_Utrecht'     in userZones()) ||
        (z == 'Hoornaar_Zeist'      && 'Zeist'      in userZones()) ||
        (z == 'Hoornaar_Bilthoven'  && 'Bilthoven'  in userZones()) ||
        (z == 'Hoornaar_Driebergen' && 'Driebergen' in userZones()) ||
        (z == 'Hoornaar_Utrecht'    && 'Utrecht'     in userZones())
      );
    }

    match /maps/{year}/{group}/data/markers/{docId} {
      allow read: if true;
      allow create: if isAdmin() || canWriteZone(request.resource.data.zoneId);
      allow update: if isAdmin() || (canWriteZone(request.resource.data.zoneId) && canWriteZone(resource.data.zoneId));
      allow delete: if isAdmin() || canWriteZone(resource.data.zoneId);
    }

    match /maps/{year}/{group}/data/lines/{docId} {
      allow read: if true;
      allow create: if isAdmin() || canWriteZone(request.resource.data.zoneId);
      allow update: if isAdmin() || (canWriteZone(request.resource.data.zoneId) && canWriteZone(resource.data.zoneId));
      allow delete: if isAdmin() || canWriteZone(resource.data.zoneId);
    }

    match /maps/{year}/{group}/data/sectors/{docId} {
      allow read: if true;
      allow create: if isAdmin() || canWriteZone(request.resource.data.zoneId);
      allow update: if isAdmin() || (canWriteZone(request.resource.data.zoneId) && canWriteZone(resource.data.zoneId));
      allow delete: if isAdmin() || canWriteZone(resource.data.zoneId);
    }

    match /maps/{year}/{group}/data/polygons/{docId} {
      allow read: if true;
      allow create: if isAdmin() || canWriteZone(request.resource.data.zoneId);
      allow update: if isAdmin() || (canWriteZone(request.resource.data.zoneId) && canWriteZone(resource.data.zoneId));
      allow delete: if isAdmin() || canWriteZone(resource.data.zoneId);
    }

    match /roles/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update, delete: if isAdmin();
    }
  }
}
