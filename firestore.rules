// Fix 14 — drie rollen + auto-registratie pending gebruikers
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn()  { return request.auth != null; }
    function uid()         { return request.auth.uid; }
    function roleDoc()     { return get(/databases/{database}/documents/roles/$(uid())); }
    function userRole()    { return roleDoc().data.role; }
    function userZones()   { return roleDoc().data.zones; }

    function isAdmin()     { return isSignedIn() && userRole() == 'admin'; }
    function isManager()   { return isSignedIn() && userRole() == 'manager'; }
    function isVolunteer() { return isSignedIn() && userRole() == 'volunteer'; }
    function canWrite()    { return isAdmin() || isManager() || isVolunteer(); }

    // Mag schrijven in dit gebied?
    function canWriteInGroup(group) {
      return isAdmin()
          || ( (isManager() || isVolunteer()) && group in userZones() );
    }

    // ── Markers, lijnen, sectoren ──────────────────────────────────
    match /maps/{year}/{group}/data/markers/{docId} {
      allow read: if true;
      allow create, update, delete: if canWriteInGroup(group);
    }
    match /maps/{year}/{group}/data/lines/{docId} {
      allow read: if true;
      allow create, update, delete: if canWriteInGroup(group);
    }
    match /maps/{year}/{group}/data/sectors/{docId} {
      allow read: if true;
      allow create, update, delete: if canWriteInGroup(group);
    }

    // ── Polygonen (gebieden tekenen) ───────────────────────────────
    match /maps/{year}/{group}/data/polygons/{docId} {
      allow read: if true;
      allow create: if isAdmin() || isManager();
      allow update, delete:
        if isAdmin()
        || ( isManager() && resource.data.createdBy == uid() );
    }

    // ── Rollen ────────────────────────────────────────────────────
    match /roles/{userId} {
      // Eigen rol lezen (ook pending)
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // Eigen rol aanmaken alleen als pending (auto-registratie bij eerste login)
      allow create: if isSignedIn()
                    && request.auth.uid == userId
                    && request.resource.data.role == 'pending';
      // Alleen admin mag rollen wijzigen
      allow update, delete: if isAdmin();
    }
  }
}
